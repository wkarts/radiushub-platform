APP_NAME="RadiusHub Playground"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8080
APP_TIMEZONE=America/Bahia
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR
APP_VERSION=1.4.2
APP_AUTHOR="WWSoftware's Sistemas"
DEPLOYMENT_MODE=playground
TRUSTED_PROXIES=*
PLAYGROUND_MODE=true
PLAYGROUND_BANNER=true
PLAYGROUND_MIKROTIK_SIMULATOR=true
PLAYGROUND_ALLOW_PRODUCTION=false
RADIUSHUB_ENV_FILE=.env.playground

LOG_CHANNEL=stack
LOG_STACK=stderr
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=radiushub_playground
DB_USERNAME=radiushub
DB_PASSWORD=change-this-database-password
DB_SSLMODE=prefer
COMPOSE_PROFILES=postgres

SESSION_DRIVER=database
SESSION_LIFETIME=240
SESSION_ENCRYPT=true
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

CACHE_STORE=failover
CACHE_FAILOVER_STORES=redis,database
CACHE_LIMITER=database
QUEUE_CONNECTION=redis
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@playground.local"
MAIL_FROM_NAME="${APP_NAME}"

RADIUS_CREDENTIAL_KEY=change-this-radius-credential-key
RADIUS_LOCAL_SECRET=change-this-local-radius-secret
RADIUS_BIND_ADDRESS=127.0.0.1
RADIUS_AUTH_PORT=1812
RADIUS_ACCT_PORT=1813
RADIUS_COA_PORT=3799
RADIUS_TIMEOUT_SECONDS=3
RADIUS_RADCLIENT_BINARY=/usr/bin/radclient
RADIUS_CLOSE_STALE_AFTER_HOURS=48
RADIUS_CLIENT_RELOAD_SECONDS=0

SEED_ADMIN_NAME="Administrador Playground"
SEED_ADMIN_EMAIL=admin@playground.local
SEED_ADMIN_PASSWORD=ChangeMe@123!
SEED_DEMO=true

# O PlaygroundSeeder cria tenant, empresa e usuários próprios.
PLATFORM_BOOTSTRAP_ENABLED=false
SEED_ADMIN_LOGIN=playground.admin
SEED_ADMIN_FORCE_PASSWORD=false
SEED_ADMIN_MUST_CHANGE_PASSWORD=false
SEED_DEFAULT_TENANT=false
SEED_DEFAULT_COMPANY=false
SEED_PREFER_EXISTING_CONTEXT=true
SEED_ATTACH_ALL_SUPER_ADMINS=true
PLAYGROUND_ADMIN_EMAIL=admin@playground.local
PLAYGROUND_ADMIN_PASSWORD=ChangeMe@123!
PLAYGROUND_OPERATOR_EMAIL=operador@playground.local
PLAYGROUND_OPERATOR_PASSWORD=Operador@123!
PLAYGROUND_TECHNICIAN_EMAIL=tecnico@playground.local
PLAYGROUND_TECHNICIAN_PASSWORD=Tecnico@123!
PLAYGROUND_NETWORK_USERNAME=cliente.demo
PLAYGROUND_NETWORK_PASSWORD=ClienteDemo@123
PLAYGROUND_NAS_IP_ADDRESS=127.0.0.10

ASAAS_WEBHOOK_NAME="RadiusHub Playground"
ASAAS_WEBHOOK_SEND_TYPE=SEQUENTIALLY

AUTO_MIGRATE=true
AUTO_SEED=true
APP_BIND_ADDRESS=127.0.0.1
APP_PORT=8080
RADIUSHUB_REGISTRY=ghcr.io/wkarts
RADIUSHUB_TAG=1.4.2

MIKROTIK_SSH_CONNECTION_TIMEOUT=5
MIKROTIK_SSH_COMMAND_TIMEOUT=10
MIKROTIK_SSH_KEY_BITS=3072
MIKROTIK_SSH_ALLOW_PASSWORD_FALLBACK=false
MIKROTIK_SSH_REQUIRE_HOST_FINGERPRINT=true
MIKROTIK_AUTO_SYNC_ON_CHANGE=true
MIKROTIK_SYNC_BATCH_SIZE=100
MIKROTIK_SYNC_CONTINUE_ON_ERROR=true
MIKROTIK_SESSION_CONTROL_DRIVER=ssh
MIKROTIK_ALLOW_COA_FALLBACK=false
