APP_NAME=RadiusHub
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://radius.example.com
APP_TIMEZONE=America/Bahia
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR
APP_VERSION=1.4.0
APP_AUTHOR="WWSoftware's Sistemas"
APP_PORT=8080
DEPLOYMENT_MODE=docker
RADIUSHUB_ENV_FILE=.env
TRUSTED_PROXIES=*

# Modo de demonstração: mantenha desabilitado em produção.
PLAYGROUND_MODE=false
PLAYGROUND_BANNER=false
PLAYGROUND_MIKROTIK_SIMULATOR=false
PLAYGROUND_ALLOW_PRODUCTION=false

LOG_CHANNEL=stack
LOG_STACK=stderr
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=radiushub
DB_USERNAME=radiushub
DB_PASSWORD=change-this-database-password
DB_SSLMODE=prefer
COMPOSE_PROFILES=mysql

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

CACHE_STORE=failover
CACHE_FAILOVER_STORES=redis,database
CACHE_LIMITER=database
QUEUE_CONNECTION=redis
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@localhost"
MAIL_FROM_NAME="${APP_NAME}"

RADIUS_CREDENTIAL_KEY=change-this-radius-credential-key
RADIUS_LOCAL_SECRET=change-this-local-radius-secret
RADIUS_AUTH_PORT=1812
RADIUS_ACCT_PORT=1813
RADIUS_COA_PORT=3799
RADIUS_TIMEOUT_SECONDS=3
RADIUS_RADCLIENT_BINARY=/usr/bin/radclient
RADIUS_CLOSE_STALE_AFTER_HOURS=48
RADIUS_CLIENT_RELOAD_SECONDS=30

SEED_ADMIN_NAME=Administrador
SEED_ADMIN_EMAIL=admin@localhost
SEED_ADMIN_PASSWORD=ChangeMe@123!
SEED_DEMO=false

# Bootstrap idempotente do acesso inicial
PLATFORM_BOOTSTRAP_ENABLED=true
SEED_ADMIN_LOGIN=admin
SEED_ADMIN_FORCE_PASSWORD=false
SEED_ADMIN_MUST_CHANGE_PASSWORD=true
SEED_DEFAULT_TENANT=true
SEED_PREFER_EXISTING_CONTEXT=true
SEED_ATTACH_ALL_SUPER_ADMINS=true
SEED_TENANT_NAME="RadiusHub Principal"
SEED_TENANT_SLUG=principal
SEED_TENANT_DOCUMENT=
SEED_TENANT_EMAIL="${SEED_ADMIN_EMAIL}"
SEED_TENANT_PHONE=
SEED_TENANT_TIMEZONE="${APP_TIMEZONE}"
SEED_TENANT_PLAN=platform
SEED_DEFAULT_COMPANY=true
SEED_COMPANY_LEGAL_NAME="Empresa Principal"
SEED_COMPANY_TRADE_NAME="Empresa Principal"
SEED_COMPANY_DOCUMENT=
SEED_COMPANY_EMAIL="${SEED_ADMIN_EMAIL}"
SEED_COMPANY_PHONE=
SEED_COMPANY_PLAN=platform
ASAAS_WEBHOOK_NAME="RadiusHub - Pagamentos"
ASAAS_WEBHOOK_SEND_TYPE=SEQUENTIALLY
AUTO_MIGRATE=true
AUTO_SEED=true

RADIUSHUB_REGISTRY=ghcr.io/wkarts
RADIUSHUB_TAG=1.4.0

# Integração MikroTik por SSH Key
MIKROTIK_SSH_CONNECTION_TIMEOUT=10
MIKROTIK_SSH_COMMAND_TIMEOUT=30
MIKROTIK_SSH_KEY_BITS=3072
MIKROTIK_SSH_ALLOW_PASSWORD_FALLBACK=false
MIKROTIK_SSH_REQUIRE_HOST_FINGERPRINT=false
MIKROTIK_AUTO_SYNC_ON_CHANGE=true
MIKROTIK_SYNC_BATCH_SIZE=100
MIKROTIK_SYNC_CONTINUE_ON_ERROR=true
MIKROTIK_SESSION_CONTROL_DRIVER=ssh
MIKROTIK_ALLOW_COA_FALLBACK=false
