APP_NAME=RadiusHub
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8080
APP_TIMEZONE=America/Bahia
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR
APP_VERSION=1.2.0
APP_AUTHOR="WWSoftware's Sistemas"
APP_PORT=8080
DEPLOYMENT_MODE=docker
TRUSTED_PROXIES=*

LOG_CHANNEL=stack
LOG_STACK=stderr
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=radiushub
DB_USERNAME=radiushub
DB_PASSWORD=change-this-database-password
DB_SSLMODE=prefer
COMPOSE_PROFILES=mysql

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

CACHE_STORE=failover
CACHE_FAILOVER_STORES=redis,database
CACHE_LIMITER=database
QUEUE_CONNECTION=redis
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@localhost"
MAIL_FROM_NAME="${APP_NAME}"

RADIUS_CREDENTIAL_KEY=change-this-radius-credential-key
RADIUS_LOCAL_SECRET=change-this-local-radius-secret
RADIUS_AUTH_PORT=1812
RADIUS_ACCT_PORT=1813
RADIUS_COA_PORT=3799
RADIUS_TIMEOUT_SECONDS=3
RADIUS_RADCLIENT_BINARY=/usr/bin/radclient
RADIUS_CLOSE_STALE_AFTER_HOURS=48
RADIUS_CLIENT_RELOAD_SECONDS=30

SEED_ADMIN_NAME=Administrador
SEED_ADMIN_EMAIL=admin@localhost
SEED_ADMIN_PASSWORD=ChangeMe@123!
SEED_DEMO=false
ASAAS_WEBHOOK_NAME="RadiusHub - Pagamentos"
ASAAS_WEBHOOK_SEND_TYPE=SEQUENTIALLY
AUTO_MIGRATE=true
AUTO_SEED=true

RADIUSHUB_REGISTRY=ghcr.io/wkarts
RADIUSHUB_TAG=1.2.0
