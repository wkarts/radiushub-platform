{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "wwsoftwares/radiushub-platform",
    "type": "project",
    "description": "Plataforma multi-tenant Laravel para Hotspot, PPPoE, FreeRADIUS, MikroTik e cobrança.",
    "keywords": [
        "billing",
        "freeradius",
        "hotspot",
        "laravel",
        "mikrotik",
        "multi-tenant",
        "pppoe",
        "rbac",
        "ssh",
        "voucher"
    ],
    "license": "proprietary",
    "require": {
        "argws/asaas-sdk-php": "0.2.62",
        "ext-json": "*",
        "ext-pdo": "*",
        "laravel/framework": "^13.8",
        "ext-mbstring": "*",
        "ext-openssl": "*",
        "laravel/tinker": "^3.0",
        "php": "^8.3",
        "phpseclib/phpseclib": "^3.0.55",
        "barryvdh/laravel-dompdf": "^3.1",
        "pragmarx/google2fa": "^9.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.24",
        "laravel/pail": "^1.2.5",
        "laravel/pint": "^1.27",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpunit/phpunit": "^12.5.12"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php artisan storage:link --ansi"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "lint": [
            "@php -d detect_unicode=0 scripts/php-lint.php"
        ],
        "migrations:check": [
            "@php scripts/check-migration-integrity.php"
        ],
        "version:check": [
            "@php scripts/check-version-integrity.php"
        ],
        "planning:check": [
            "@php scripts/check-planning-compliance.php"
        ],
        "radius:check": [
            "@php scripts/check-freeradius-templates.php"
        ],
        "doctor": [
            "@php artisan radiushub:doctor"
        ],
        "test:unit": [
            "@php artisan test --testsuite=Unit"
        ],
        "test:feature": [
            "@php artisan test --testsuite=Feature"
        ],
        "playground:verify": [
            "@php artisan radiushub:playground:verify"
        ],
        "health:ready": [
            "@php artisan radiushub:health --ready"
        ],
        "smoke:http": [
            "bash scripts/smoke-http.sh"
        ],
        "deployment:check": [
            "bash scripts/validate-deployment.sh"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "packages/asaas-sdk-argws",
            "options": {
                "symlink": false
            }
        }
    ]
}
