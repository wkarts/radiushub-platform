{
  "name": "argws/asaas-sdk-php",
  "description": "SDK PHP NÃO OFICIAL para a API do Asaas. Baseada na SDK Java e gerada a partir da documentação/OpenAPI.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.1",
    "ext-json": "*",
    "guzzlehttp/guzzle": "^7.8",
    "psr/log": "^3.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "phpstan/phpstan": "^1.10",
    "friendsofphp/php-cs-fixer": "^3.56"
  },
  "autoload": {
    "psr-4": {
      "Asaas\\Sdk\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Asaas\\Sdk\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "asaas:build-openapi": "php bin/build-openapi.php",
    "asaas:generate": "php bin/generate-sdk.php",
    "asaas:sdk-build": [
      "php bin/build-openapi.php",
      "php bin/generate-sdk.php"
    ],
    "asaas:verify": "php bin/verify-parity.php",
    "test": "phpunit",
    "lint": [
      "phpstan analyse",
      "php-cs-fixer fix --dry-run --diff"
    ]
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "version": "0.2.62"
}
