APP_NAME=RadiusHub
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://radius.example.com
APP_TIMEZONE=America/Bahia
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR
APP_VERSION=1.3.0
APP_AUTHOR="WWSoftware's Sistemas"
DEPLOYMENT_MODE=native
TRUSTED_PROXIES=*

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=info

# MySQL 8+ ou PostgreSQL 15+. Para Docker use um dos arquivos .env.docker.*.example.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=radiushub
DB_USERNAME=radiushub
DB_PASSWORD=change-this-database-password
DB_SSLMODE=prefer

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# CloudPanel nativo funciona sem Redis. Para Redis altere ambos para redis.
CACHE_STORE=database
CACHE_LIMITER=database
CACHE_FAILOVER_STORES=redis,database
QUEUE_CONNECTION=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Chave independente compartilhada entre Laravel e FreeRADIUS.
# Gere com: openssl rand -base64 48 | tr -d '\n'
RADIUS_CREDENTIAL_KEY=change-this-radius-credential-key
RADIUS_LOCAL_SECRET=change-this-local-radius-secret
RADIUS_AUTH_PORT=1812
RADIUS_ACCT_PORT=1813
RADIUS_COA_PORT=3799
RADIUS_TIMEOUT_SECONDS=3
RADIUS_RADCLIENT_BINARY=/usr/bin/radclient
RADIUS_CLOSE_STALE_AFTER_HOURS=48
RADIUS_CLIENT_RELOAD_SECONDS=30

SEED_ADMIN_NAME=Administrador
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe@123!
SEED_DEMO=false

ASAAS_WEBHOOK_NAME="RadiusHub - Pagamentos"
ASAAS_WEBHOOK_SEND_TYPE=SEQUENTIALLY

AUTO_MIGRATE=false
AUTO_SEED=false

# Integração MikroTik por SSH Key
MIKROTIK_SSH_CONNECTION_TIMEOUT=10
MIKROTIK_SSH_COMMAND_TIMEOUT=30
MIKROTIK_SSH_KEY_BITS=3072
MIKROTIK_SSH_ALLOW_PASSWORD_FALLBACK=false
MIKROTIK_SSH_REQUIRE_HOST_FINGERPRINT=false
MIKROTIK_AUTO_SYNC_ON_CHANGE=true
MIKROTIK_SYNC_BATCH_SIZE=100
MIKROTIK_SYNC_CONTINUE_ON_ERROR=true
MIKROTIK_SESSION_CONTROL_DRIVER=ssh
MIKROTIK_ALLOW_COA_FALLBACK=false
